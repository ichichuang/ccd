{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ccd-desktop",
  "version": "0.1.1",
  "identifier": "com.ichichuang.ccd",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8088",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Enterprise Vue Admin",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
