{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimum required permissions for ccd-desktop",
  "windows": ["main", "route-*"],
  "permissions": [
    "core:window:default",
    "core:webview:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "core:app:default",
    "core:resources:default",
    "core:event:default",
    "shell:allow-open",
    "window-state:default"
  ]
}
