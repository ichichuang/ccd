{
  "schemaVersion": 1,
  "runtimeNeutralScanRoots": [
    "packages/core/src",
    "packages/contracts/src"
  ],
  "runtimeNeutralPackagePaths": [
    "packages/core/src",
    "packages/contracts/src"
  ],
  "forbiddenImports": [
    "^node:",
    "^(fs|path|os|process|child_process|worker_threads|http|https|stream|crypto)$",
    "^@tauri-apps/"
  ],
  "forbiddenIdentifiers": [
    "window",
    "document",
    "navigator",
    "localStorage",
    "sessionStorage",
    "XMLHttpRequest",
    "process",
    "console",
    "setTimeout",
    "setInterval"
  ],
  "forbiddenCalls": [
    "fetch",
    "invoke"
  ],
  "forbiddenPropertyRoots": [
    "crypto"
  ],
  "forbiddenSourcePatterns": [
    "\\bwindow\\b",
    "\\bdocument\\b",
    "\\bnavigator\\b",
    "\\blocalStorage\\b",
    "\\bsessionStorage\\b",
    "\\bfetch\\s*\\(",
    "\\bXMLHttpRequest\\b",
    "\\bprocess\\b",
    "\\bconsole\\.",
    "\\bcrypto\\.",
    "\\bsetTimeout\\s*\\(",
    "\\bsetInterval\\s*\\("
  ],
  "adapterBoundaries": [
    {
      "name": "tauri",
      "allowedPath": "apps/desktop/src/adapters",
      "forbiddenImportPattern": "^@tauri-apps/",
      "forbiddenCallPattern": "\\binvoke\\s*\\("
    }
  ]
}
