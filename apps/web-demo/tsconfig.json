{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*", "vite.config.ts", "build/**/*.ts", "../vite.shared.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/apps-web-demo.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "preserve",
    "jsxImportSource": "vue",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@!/*": ["./src/api/*"],
      "@&/*": ["./src/layouts/components/*"]
    },
    "types": ["vite/client"]
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    "target": 3.5,
    "strict": true
  }
}
