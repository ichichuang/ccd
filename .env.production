# ==========================================
# 应用基础配置（如版本、环境等）
# ==========================================

# Pinia 持久化存储 Key 前缀
VITE_PINIA_PERSIST_KEY_PREFIX=ccd-storage-pro

# 应用 storage 混淆材料（客户端可见，不是服务端 secret）
# 如需跨部署保持同一组 client-side obfuscation，可通过 CI/CD 注入同名 public 值
# 若未注入，构建时 core.ts 将使用运行时指纹作为 fallback
VITE_PUBLIC_STORAGE_OBFUSCATION_KEY=${VITE_PUBLIC_STORAGE_OBFUSCATION_KEY:-}

# 应用根路径（通常保持 /）
VITE_PUBLIC_PATH=/

# 登录成功后的根路径重定向
VITE_ROOT_REDIRECT=/dashboard

# 当前运行环境（development | production）- 用于区分环境
VITE_APP_ENV=production


# ==========================================
# API 接口配置
# ==========================================

# API 基础地址 - 生产环境的接口根地址
VITE_API_BASE_URL=https://www.server.wzdxcc.cloudns.org/

# 公共演示部署 opt-in；真实生产默认必须保持 false
VITE_PUBLIC_DEMO_ENABLED=false

# 旧版演示 mock 开关；生产环境不会单独信任该值，公共演示请设置 VITE_PUBLIC_DEMO_ENABLED=true
VITE_DEMO_MOCK_ENABLED=false

# 客户端请求超时（毫秒）
VITE_API_TIMEOUT=10000

# 系统偏好跨设备同步 WebSocket 地址；未配置时自动跳过 WebSocket transport
# VITE_SYNC_WS_URL=wss://www.server.wzdxcc.cloudns.org/ws/preferences


# ==========================================
# 构建优化配置
# ==========================================

# 是否在构建中移除 debugger 语句（true | false）
VITE_DROP_DEBUGGER=true

# 是否在构建中移除 console 语句（true | false）
VITE_DROP_CONSOLE=true

# 构建产物压缩（gzip | brotli | both | none），生产同时生成 .gz 与 .br
VITE_COMPRESSION=both
