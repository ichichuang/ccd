#!/usr/bin/env sh
set -e

repair_hint='Run: pnpm worktree:init'

require_path() {
  if [ ! -e "$1" ]; then
    echo "[hook] missing required generated/runtime asset: $1"
    echo "[hook] $repair_hint"
    exit 1
  fi
}

require_path AGENTS.md
require_path CLAUDE.md
require_path .ai/runtime/repair_list.txt
require_path .ai/governance-snapshot.json

echo "Running governance gate..."
pnpm governance:verify
pnpm ai:doctor
pnpm drift-check
pnpm lint:staged:safe

echo "Local governance checks passed."
