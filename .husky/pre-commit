#!/usr/bin/env sh
set -e

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RUNTIME="$ROOT_DIR/scripts/exec.sh"

run_pnpm() {
  bash "$RUNTIME" pnpm "$@"
}

echo "Running project metadata validation..."
run_pnpm project:validate

echo "Running TypeScript checks..."
run_pnpm type-check

echo "Running lint checks..."
run_pnpm lint:check

echo "Running architecture boundary checks..."
run_pnpm arch:boundaries
run_pnpm arch:runtime

echo "Pre-commit checks passed."
