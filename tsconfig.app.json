{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // ✅ 必须项：开启 JSX 支持
    "jsx": "preserve",
    "jsxImportSource": "vue",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      // API 目录为两级：src/api/<module>/<feature>.ts
      // 需要同时支持 @!/module 与 @!/module/feature 两种引用形态
      "@!/*": ["./src/api/*"],
      "@&/*": ["./src/layouts/components/*"]
    },
    // vite/client 提供 import.meta.env / import.meta.hot 等 Vite 专属类型。
    // 不应包含 "node"（会将 process/Buffer/__dirname 等 Node 全局量暴露给浏览器编译上下文）。
    "types": ["vite/client"]
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    // target: 3.3 保持原值 — 升级至 3.5 导致 vue-tsc 2.2.10 将 <Transition>/<TransitionGroup>
    // 等内置组件报错 "Property 'X' does not exist on type '{}'", 待 vue-language-tools 修复后再升级。
    "target": 3.3,
    "strict": true
  }
}
