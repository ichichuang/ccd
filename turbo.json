{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env",
    ".env.*",
    ".ai/governance/policies/*.json",
    "eslint.config.*",
    "package.json",
    "playwright.config.*",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "project.config.json",
    "tsconfig*.json",
    "turbo.json",
    "uno.config.*",
    "vite.config.*",
    "vitest.config.*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!coverage/**",
        "!dist/**",
        "!playwright-report/**",
        "!test-results/**"
      ],
      "outputs": ["dist/**"],
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "!dist/**"],
      "outputs": [],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["type-check"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json", "!dist/**"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.spec.*",
        "**/*.test.*",
        "vitest.config.*",
        "!coverage/**",
        "!dist/**"
      ],
      "outputs": [],
      "cache": true
    },
    "//#lint": {
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.*", "tsconfig*.json", "!dist/**"],
      "outputs": [],
      "cache": true
    },
    "//#e2e": {
      "dependsOn": ["@ccd/web-demo#build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/**",
        "e2e/**",
        "packages/**",
        "playwright.config.*",
        "!**/dist/**",
        "!**/node_modules/**"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    }
  }
}
