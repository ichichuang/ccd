{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    // ✅ Node 侧仅负责工具链与构建脚本
    "vite.config.ts",
    "uno.config.ts",
    "eslint.config.ts",
    "vitest.config.ts",
    "cypress.config.ts",
    "playwright.config.ts",
    "commitlint.config.ts",
    "build/**/*",
    "scripts/**/*.ts",

    // ✅ Node 侧需要的全局类型声明
    "src/types/**/*.d.ts",

    // ✅ 供 uno.config.ts 等工具链引用的浏览器常量与类型
    "src/constants/**/*.ts",
    "src/utils/theme/metadata.ts",
    "src/utils/theme/colors.ts",
    "src/views/system-configuration/configs/shortcutGroups.ts",
    "src/locales/**/*"
  ],
  "exclude": [
    // 自动生成的类型声明文件，不参与 Node 编译（避免 DOM/browser 类型污染）
    "src/types/auto-imports.d.ts",
    "src/types/components.d.ts",
    // router.ts 使用了 import.meta.env（Vite 浏览器专属 API），
    // 在 Node 上下文中没有此 API，必须排除以防止类型冲突。
    // 根本原因：src/constants/**/*.ts 通配包含了此文件，故需显式排除。
    "src/constants/router.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"]
  }
}
