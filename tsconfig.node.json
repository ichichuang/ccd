{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    // ✅ Node 侧仅负责工具链与构建脚本
    "vite.config.ts",
    "uno.config.ts",
    "eslint.config.ts",
    "vitest.config.ts",
    "cypress.config.ts",
    "playwright.config.ts",
    "commitlint.config.ts",
    "build/**/*",
    "scripts/**/*.ts",

    // ✅ Node 侧需要的全局类型声明
    "src/types/**/*.d.ts",

    // ✅ 供 uno.config.ts 等工具链引用的浏览器常量与类型
    "src/constants/**/*.ts",
    "src/utils/theme/metadata.ts",
    "src/views/system-configuration/configs/shortcutGroups.ts",
    "src/locales/**/*"
  ],
  "exclude": [
    "src/types/auto-imports.d.ts",
    "src/types/components.d.ts",
    "src/constants/router.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"]
  }
}
