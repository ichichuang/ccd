{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ccd-ui-source-fixtures/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "declaredCounts", "cases"],
  "properties": {
    "schemaVersion": { "const": "ccd-ui-source-fixtures/v1" },
    "declaredCounts": {
      "type": "object", "additionalProperties": false,
      "required": ["total", "positive", "negative", "rule", "owner", "falsePositive", "exception", "parserFailure", "unsupportedScss", "fingerprintResult", "baselineRender", "gitMode", "safety"],
      "properties": { "total": { "const": 162 }, "positive": { "const": 82 }, "negative": { "const": 80 }, "rule": { "const": 92 }, "owner": { "const": 12 }, "falsePositive": { "const": 12 }, "exception": { "const": 5 }, "parserFailure": { "const": 5 }, "unsupportedScss": { "const": 7 }, "fingerprintResult": { "const": 3 }, "baselineRender": { "const": 16 }, "gitMode": { "const": 6 }, "safety": { "const": 4 } }
    },
    "cases": { "type": "array", "minItems": 162, "maxItems": 162, "items": { "$ref": "#/definitions/case" } }
  },
  "definitions": {
    "case": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "group", "polarity", "expectedExit", "expectedReason", "fixturePath", "ruleId", "detectorId"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "group": { "enum": ["rule", "owner", "false-positive", "exception", "parser-failure", "unsupported-scss", "fingerprint-result", "baseline-render", "git-mode", "safety"] },
        "polarity": { "enum": ["positive", "negative"] },
        "expectedExit": { "type": "integer", "minimum": 0, "maximum": 10 },
        "expectedReason": { "type": ["string", "null"] },
        "fixturePath": { "type": ["string", "null"] },
        "ruleId": { "type": ["string", "null"], "pattern": "^CCD-UI-\\d{3}$" },
        "detectorId": { "type": ["string", "null"] }
      }
    }
  }
}
