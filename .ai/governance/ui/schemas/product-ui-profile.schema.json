{
  "$id": "https://ccd.wzdxcc.cloudns.org/governance/ui/product-ui-profile.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCD Product UI Profile",
  "description": "Schema for a replaceable Product UI Profile that consumes platform invariants.",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "version",
    "status",
    "identity",
    "invariants",
    "tokens",
    "surfaces",
    "motionCeiling",
    "replacementBoundary"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^ccd-ui-profile/v\\d+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "published", "deprecated"] },
    "identity": {
      "type": "object",
      "required": ["purpose", "expression"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "expression": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "invariants": {
      "type": "object",
      "required": ["mustPreserve"],
      "properties": {
        "mustPreserve": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tokens": {
      "type": "object",
      "required": ["sourceOfTruth", "families"],
      "properties": {
        "sourceOfTruth": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "families": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "required": ["materialMapping", "prohibited"],
      "properties": {
        "materialMapping": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "prohibited": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "motionCeiling": {
      "type": "object",
      "required": ["defaultTool", "conditionalTools"],
      "properties": {
        "defaultTool": { "type": "string", "enum": ["none", "css", "animate-lite", "gsap"] },
        "conditionalTools": {
          "type": "array",
          "items": { "type": "string", "enum": ["css", "animate-lite", "gsap"] }
        }
      }
    },
    "replacementBoundary": {
      "type": "object",
      "required": ["requiresGovernanceApproval", "cannotWeaken"],
      "properties": {
        "requiresGovernanceApproval": { "type": "boolean" },
        "cannotWeaken": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
