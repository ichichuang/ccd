{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ccd-ui-source-baseline/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "baselineCommit", "policyDigest", "scannerManifestDigest", "scannerVersion", "fingerprintAlgorithm", "ruleCoverageSummary", "detectorCoverageSummary", "declaredFindingCount", "declaredFingerprintCount", "declaredRuleCount", "declaredFileCount", "entries", "scannerModuleDigests"],
  "properties": {
    "schemaVersion": { "const": "ccd-ui-source-baseline/v1" },
    "repository": { "const": "ichichuang/ccd" },
    "baselineCommit": { "pattern": "^[0-9a-f]{40}$" },
    "policyDigest": { "$ref": "#/definitions/digest" },
    "scannerManifestDigest": { "$ref": "#/definitions/digest" },
    "scannerVersion": { "const": "1.0.0" },
    "fingerprintAlgorithm": { "const": "sha256:ccd-ui-fingerprint/v1" },
    "ruleCoverageSummary": { "$ref": "#/definitions/ruleSummary" },
    "detectorCoverageSummary": { "$ref": "#/definitions/detectorSummary" },
    "declaredFindingCount": { "type": "integer", "minimum": 0 },
    "declaredFingerprintCount": { "type": "integer", "minimum": 0 },
    "declaredRuleCount": { "const": 68 },
    "declaredFileCount": { "const": 554 },
    "entries": { "type": "array", "items": { "$ref": "#/definitions/entry" } },
    "scannerModuleDigests": { "type": "object", "minProperties": 28, "maxProperties": 28, "additionalProperties": { "$ref": "#/definitions/digest" } }
  },
  "definitions": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "ruleSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["sourceEnforceable", "assisted", "schemaEnforced", "humanReviewOnly", "sourceCapable", "total"],
      "properties": { "sourceEnforceable": { "const": 24 }, "assisted": { "const": 22 }, "schemaEnforced": { "const": 8 }, "humanReviewOnly": { "const": 14 }, "sourceCapable": { "const": 46 }, "total": { "const": 68 } }
    },
    "detectorSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["declared", "sourceCapable", "schemaOnly", "humanOnly", "executed"],
      "properties": { "declared": { "const": 14 }, "sourceCapable": { "const": 12 }, "schemaOnly": { "const": 1 }, "humanOnly": { "const": 1 }, "executed": { "const": 12 } }
    },
    "location": {
      "type": "object", "additionalProperties": false,
      "required": ["line", "column", "endLine", "endColumn"],
      "properties": { "line": { "type": "integer", "minimum": 1 }, "column": { "type": "integer", "minimum": 1 }, "endLine": { "type": "integer", "minimum": 1 }, "endColumn": { "type": "integer", "minimum": 1 } }
    },
    "entry": {
      "type": "object", "additionalProperties": false,
      "required": ["fingerprint", "ruleId", "detectorId", "path", "normalizedEvidence", "ownerKey", "count", "locations"],
      "properties": {
        "fingerprint": { "$ref": "#/definitions/digest" },
        "ruleId": { "pattern": "^CCD-UI-\\d{3}$" },
        "detectorId": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._@/-]+$" },
        "normalizedEvidence": { "type": "object" },
        "ownerKey": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 },
        "locations": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/location" } }
      }
    }
  }
}
