{
  "$id": "https://ccd.wzdxcc.cloudns.org/governance/ui/ui-exception.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCD UI Policy Exception",
  "description": "A single registered exception to a CCD-UI policy rule.",
  "type": "object",
  "required": [
    "id",
    "ruleId",
    "scope",
    "justification",
    "authority",
    "approvedBy",
    "createdAt",
    "expiresAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^CCD-UI-EXC-\\d{4}$" },
    "ruleId": { "type": "string", "pattern": "^CCD-UI-\\d{3}$" },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "justification": { "type": "string", "minLength": 20 },
    "authority": { "type": "string", "minLength": 1 },
    "approvedBy": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "reviewedAt": { "type": "string", "format": "date-time" }
  }
}
