{
  "$id": "https://ccd.wzdxcc.cloudns.org/governance/ui/ui-exception-registry.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCD UI Policy Exception Registry",
  "description": "Registry of approved exceptions to CCD-UI policy rules.",
  "type": "object",
  "required": ["schemaVersion", "policyId", "exceptions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^ccd-ui-exception-registry/v\\d+$" },
    "policyId": { "const": "ccd-ui-policy/v2" },
    "exceptions": {
      "type": "array",
      "items": { "$ref": "ui-exception.schema.json" }
    }
  }
}
