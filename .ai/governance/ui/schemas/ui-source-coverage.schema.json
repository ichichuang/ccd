{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ccd-ui-source-coverage/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "counts", "pageContractDeferrals", "bindings"],
  "properties": {
    "schemaVersion": { "const": "ccd-ui-source-coverage/v1" },
    "repository": { "const": "ichichuang/ccd" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceEnforceable", "assisted", "schemaEnforced", "humanReviewOnly", "sourceCapable", "permanentDispositions", "humanDispositions", "total"],
      "properties": {
        "sourceEnforceable": { "const": 24 },
        "assisted": { "const": 22 },
        "schemaEnforced": { "const": 8 },
        "humanReviewOnly": { "const": 14 },
        "sourceCapable": { "const": 46 },
        "permanentDispositions": { "const": 54 },
        "humanDispositions": { "const": 14 },
        "total": { "const": 68 }
      }
    },
    "pageContractDeferrals": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "enum": ["P2C-REQ-0006", "P2C-REQ-0028", "P2C-REQ-0065", "P2C-REQ-0067"] }
    },
    "bindings": {
      "type": "array",
      "minItems": 68,
      "maxItems": 68,
      "items": { "$ref": "#/definitions/binding" }
    }
  },
  "definitions": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "originalDisposition", "scannerCategory", "finalEnforcement", "detectorId", "module", "evidence", "languages", "scopeIds", "ownerContextIds", "fixtureIds", "exceptionEligible", "confidence", "humanRemainder", "pageContract", "messageId", "fingerprintKind"],
      "properties": {
        "ruleId": { "pattern": "^CCD-UI-\\d{3}$" },
        "originalDisposition": { "enum": ["permanent-rule", "human-review-only"] },
        "scannerCategory": { "enum": ["source-enforceable", "source-enforceable-with-human-remainder", "schema-enforced", "human-review-only"] },
        "finalEnforcement": { "enum": ["source-scanner-enforced", "source-scanner-assisted-human-review", "schema-validated", "human-review-only"] },
        "detectorId": { "type": "string", "minLength": 1 },
        "module": { "type": ["string", "null"] },
        "evidence": { "type": ["string", "null"] },
        "languages": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["vue", "ts", "tsx", "css", "scss", "json"] } },
        "scopeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "pattern": "^[A-Z][A-Z0-9_]+$" } },
        "ownerContextIds": { "type": "array", "uniqueItems": true, "items": { "pattern": "^OC-[A-Z0-9-]+$" } },
        "fixtureIds": { "type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": { "type": "string" } },
        "exceptionEligible": { "type": "boolean" },
        "confidence": { "enum": ["high", "bounded", "not-applicable"] },
        "humanRemainder": { "type": ["string", "null"] },
        "pageContract": { "const": null },
        "messageId": { "type": ["string", "null"] },
        "fingerprintKind": { "type": ["string", "null"] }
      }
    }
  }
}
