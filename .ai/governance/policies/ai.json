{
  "schemaVersion": 1,
  "aiSafeEvolution": true,
  "blockedGeneratedCodePatterns": [
    {
      "pattern": "from ['\"]@ccd/(core|contracts|web-demo|desktop)/",
      "reason": "AI-generated code must not introduce workspace deep imports."
    },
    {
      "pattern": "\\b(fetch|XMLHttpRequest)\\s*\\(",
      "reason": "AI-generated runtime access must use approved adapters."
    },
    {
      "pattern": "\\b(localStorage|sessionStorage)\\b",
      "reason": "AI-generated storage access must use approved storage adapters."
    }
  ],
  "allowedRuntimeAccessPaths": [
    "apps/web-demo/src/adapters/**",
    "apps/desktop/src/adapters/**",
    "packages/vue-app-platform/src/preloadError.ts"
  ],
  "requiredEntrypoints": [
    ".ai/protocol/AGENTS.core.md",
    ".ai/rules/core/00-global-architect.mdc",
    ".ai/rules/core/00-root-gatekeeper.mdc",
    ".ai/rules/core/01-global-preflight.mdc"
  ]
}
