{
  "schemaVersion": 1,
  "layers": ["contracts", "core", "frontend-platform", "apps"],
  "releaseOrder": [
    "@ccd/contracts",
    "@ccd/core",
    "@ccd/design-tokens",
    "@ccd/unocss-preset",
    "@ccd/shared-utils",
    "@ccd/vue-hooks",
    "@ccd/vue-app-platform",
    "@ccd/vue-ui",
    "@ccd/vue-primevue-adapter",
    "@ccd/vue-charts",
    "@ccd/web-demo",
    "@ccd/desktop"
  ],
  "packages": [
    {
      "name": "@ccd/contracts",
      "path": "packages/contracts",
      "layer": "contracts",
      "criticality": "critical",
      "responsibility": "Cross-runtime interfaces and DTO contracts only.",
      "allowedWorkspaceDependencies": [],
      "publicApi": true
    },
    {
      "name": "@ccd/core",
      "path": "packages/core",
      "layer": "core",
      "criticality": "critical",
      "responsibility": "Minimal runtime-neutral adapter facade; not a shared frontend bucket.",
      "allowedWorkspaceDependencies": ["@ccd/contracts"],
      "publicApi": true,
      "runtimeNeutral": true
    },
    {
      "name": "@ccd/design-tokens",
      "path": "packages/design-tokens",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared design token source and theme/size/breakpoint primitives.",
      "allowedWorkspaceDependencies": [],
      "publicApi": true,
      "runtimeNeutral": true
    },
    {
      "name": "@ccd/unocss-preset",
      "path": "packages/unocss-preset",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared UnoCSS preset, safelist, and build-time styling helpers.",
      "allowedWorkspaceDependencies": ["@ccd/design-tokens"],
      "publicApi": true,
      "runtime": "node-build"
    },
    {
      "name": "@ccd/shared-utils",
      "path": "packages/shared-utils",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Pure shared utilities.",
      "allowedWorkspaceDependencies": [],
      "publicApi": true,
      "runtimeNeutral": true
    },
    {
      "name": "@ccd/vue-hooks",
      "path": "packages/vue-hooks",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared Vue/browser composables.",
      "allowedWorkspaceDependencies": ["@ccd/shared-utils"],
      "publicApi": true,
      "runtime": "web-library"
    },
    {
      "name": "@ccd/vue-app-platform",
      "path": "packages/vue-app-platform",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared frontend app bootstrap lifecycle and platform orchestration primitives.",
      "allowedWorkspaceDependencies": ["@ccd/design-tokens"],
      "publicApi": true,
      "runtime": "web-library"
    },
    {
      "name": "@ccd/vue-ui",
      "path": "packages/vue-ui",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared Vue UI primitives.",
      "allowedWorkspaceDependencies": ["@ccd/design-tokens", "@ccd/shared-utils", "@ccd/vue-hooks"],
      "publicApi": true,
      "runtime": "web-library"
    },
    {
      "name": "@ccd/vue-primevue-adapter",
      "path": "packages/vue-primevue-adapter",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "PrimeVue-specific theme and adaptation layer.",
      "allowedWorkspaceDependencies": ["@ccd/design-tokens"],
      "publicApi": true,
      "runtime": "web-library"
    },
    {
      "name": "@ccd/vue-charts",
      "path": "packages/vue-charts",
      "layer": "frontend-platform",
      "criticality": "protected",
      "responsibility": "Shared chart runtime and helpers.",
      "allowedWorkspaceDependencies": ["@ccd/design-tokens"],
      "publicApi": true,
      "runtime": "web-library"
    },
    {
      "name": "@ccd/web-demo",
      "path": "apps/web-demo",
      "layer": "apps",
      "criticality": "flexible",
      "responsibility": "Browser app shell, routes, pages, stores, app adapters, and temporary app-local shared candidates.",
      "allowedWorkspaceDependencies": [
        "@ccd/contracts",
        "@ccd/core",
        "@ccd/design-tokens",
        "@ccd/shared-utils",
        "@ccd/unocss-preset",
        "@ccd/vue-hooks",
        "@ccd/vue-app-platform",
        "@ccd/vue-ui",
        "@ccd/vue-primevue-adapter",
        "@ccd/vue-charts"
      ],
      "publicApi": false,
      "runtime": "web"
    },
    {
      "name": "@ccd/desktop",
      "path": "apps/desktop",
      "layer": "apps",
      "criticality": "protected",
      "responsibility": "Tauri shell and desktop adapter.",
      "allowedWorkspaceDependencies": [
        "@ccd/contracts",
        "@ccd/core",
        "@ccd/design-tokens",
        "@ccd/shared-utils",
        "@ccd/unocss-preset",
        "@ccd/vue-app-platform",
        "@ccd/vue-hooks",
        "@ccd/vue-primevue-adapter",
        "@ccd/vue-ui"
      ],
      "publicApi": false,
      "runtime": "desktop",
      "adapterBoundary": "apps/desktop/src/adapters"
    }
  ],
  "forbiddenRelationships": [
    {
      "from": "packages/**",
      "to": "apps/**",
      "reason": "Packages must not depend on runtime applications."
    },
    {
      "from": "apps/**",
      "to": "apps/**",
      "reason": "Applications must not import one another."
    }
  ],
  "exportPolicy": {
    "requireExplicitRootExport": true,
    "forbidWorkspaceDeepImports": [
      "@ccd/contracts",
      "@ccd/core",
      "@ccd/design-tokens",
      "@ccd/unocss-preset",
      "@ccd/shared-utils",
      "@ccd/vue-hooks",
      "@ccd/vue-app-platform",
      "@ccd/vue-ui",
      "@ccd/vue-primevue-adapter",
      "@ccd/vue-charts",
      "@ccd/web-demo",
      "@ccd/desktop"
    ]
  }
}
