{
  "schemaVersion": 1,
  "runtimeNeutralPaths": ["packages/contracts/src", "packages/core/src"],
  "forbiddenImports": ["^node:", "^@tauri-apps/"],
  "forbiddenSourcePatterns": [
    "\\bwindow\\b",
    "\\bdocument\\b",
    "\\bnavigator\\b",
    "\\blocalStorage\\b",
    "\\bsessionStorage\\b",
    "\\bfetch\\s*\\(",
    "\\bprocess\\b",
    "\\bBuffer\\b",
    "\\bsetTimeout\\s*\\(",
    "\\bsetInterval\\s*\\("
  ],
  "adapterBoundaries": [
    {
      "name": "tauri",
      "allowedPath": "apps/desktop/src/adapters",
      "forbiddenImportPattern": "^@tauri-apps/",
      "forbiddenCallPattern": "\\binvoke\\s*\\("
    }
  ]
}
