{
  "version": 1,
  "mode": "ccd-aicc-ai-native",
  "source_of_truth": ".ai/",
  "routing_manifest": ".ai/manifests/skill-routing.json",
  "mandatory_pre_execution": {
    "dependency_audit": "package.json",
    "asset_discovery": ["src/hooks/**", "src/utils/**", "src/components/**"],
    "gap_policy": "If proposing new patterns/dependencies, explain why existing assets are insufficient."
  },
  "layers": {
    "domain": [
      {
        "id": "vue-surface",
        "skills": [".ai/skills/core/vue"],
        "rules": [
          ".ai/rules/core/03-vue3-ts-architecture.mdc",
          ".ai/rules/core/10-ai-generation-workflow.mdc",
          ".ai/rules/core/08-vue-template-strictness.mdc",
          ".ai/rules/components/00-primevue-ecosystem.mdc"
        ]
      },
      {
        "id": "state-and-composables",
        "skills": [".ai/skills/core/vueuse-functions"],
        "rules": [
          ".ai/rules/core/05-state-boundaries.mdc",
          ".ai/rules/architecture/04-store-organization.mdc",
          ".ai/rules/integrations/06-adapters-infra.mdc"
        ]
      }
    ],
    "infra": [
      {
        "id": "build-and-design-system",
        "skills": [".ai/skills/core/vite", ".ai/skills/core/unocss"],
        "rules": [
          ".ai/rules/core/02-core-engineering.mdc",
          ".ai/rules/design-system/00-unocss-guardrails.mdc",
          ".ai/rules/design-system/01-design-tokens.mdc"
        ]
      },
      {
        "id": "desktop-tauri-bridge",
        "skills": [".ai/skills/codex/desktop-tauri-guard"],
        "rules": [
          ".ai/rules/integrations/08-cross-platform-tauri.mdc",
          ".ai/rules/integrations/09-desktop-branch-governance.mdc",
          ".ai/rules/integrations/10-desktop-preflight.mdc"
        ]
      },
      {
        "id": "network-storage-flow",
        "skills": [],
        "rules": [
          ".ai/rules/integrations/00-network-routing-guardrails.mdc",
          ".ai/rules/integrations/01-http-alova.mdc",
          ".ai/rules/integrations/04-safe-storage.mdc"
        ]
      }
    ],
    "workflow": [
      {
        "id": "page-route-generation",
        "skills": [".ai/skills/codex/task-orchestrator", ".ai/skills/core/vue"],
        "rules": [
          ".ai/rules/core/01-global-preflight.mdc",
          ".ai/rules/core/10-ai-generation-workflow.mdc"
        ],
        "route_id": "page-route-scaffold"
      },
      {
        "id": "task-routing",
        "skills": [".ai/skills/codex/task-orchestrator"],
        "rules": [".ai/rules/core/01-global-preflight.mdc"],
        "route_id": "complex-or-ambiguous"
      },
      {
        "id": "browser-validation",
        "skills": [".ai/skills/codex/architecture-browser-master"],
        "rules": [
          ".ai/rules/core/02-ui-preflight.mdc",
          ".ai/rules/integrations/08-playwright-visual-regression.mdc"
        ],
        "route_id": "browser-validation"
      },
      {
        "id": "github-delivery",
        "skills": [".ai/skills/codex/github-ops"],
        "rules": [".ai/rules/core/01-global-preflight.mdc"],
        "route_id": "github-ops"
      }
    ]
  },
  "forced_directives": {
    "use_skill": "[USE SKILL]: <skill-id-or-path>",
    "use_rule": "[USE RULE]: <rule-id-or-path>"
  }
}
