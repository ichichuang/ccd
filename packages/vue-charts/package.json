{
  "name": "@ccd/vue-charts",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-artifacts.mjs paths dist ../../node_modules/.tmp/packages-vue-charts.tsbuildinfo && vite build --config vite.config.ts && vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ccd/design-tokens": "workspace:*",
    "@vueuse/core": "catalog:",
    "echarts": "catalog:",
    "vue": "catalog:",
    "vue-echarts": "catalog:",
    "vue-i18n": "catalog:"
  },
  "devDependencies": {
    "@vue/tsconfig": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue-tsc": "catalog:"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
