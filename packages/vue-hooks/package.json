{
  "name": "@ccd/vue-hooks",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-artifacts.mjs paths ../../node_modules/.tmp/packages-vue-hooks.tsbuildinfo && tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check"
  },
  "dependencies": {
    "@ccd/design-tokens": "workspace:*",
    "@ccd/shared-utils": "workspace:*",
    "@vueuse/core": "catalog:",
    "vue": "catalog:"
  }
}
