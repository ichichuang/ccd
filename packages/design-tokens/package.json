{
  "name": "@ccd/design-tokens",
  "version": "1.0.37",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -f ../../node_modules/.tmp/packages-design-tokens.tsbuildinfo && tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check",
    "test": "vitest run --passWithNoTests"
  }
}
