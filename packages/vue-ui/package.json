{
  "name": "@ccd/vue-ui",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/vue-ui.css"
  },
  "scripts": {
    "build": "rm -rf dist && rm -f ../../node_modules/.tmp/packages-vue-ui.tsbuildinfo && vite build --config vite.config.ts && vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ccd/design-tokens": "workspace:*",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-vue": "^0.5.9",
    "primevue": "^4.5.4",
    "vue": "^3.5.12",
    "vue-i18n": "^10.0.8"
  },
  "devDependencies": {
    "@vue/tsconfig": "^0.7.0",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
