{
  "name": "@ccd/vue-ui",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/vue-ui.css"
  },
  "scripts": {
    "build": "node ../../scripts/clean-artifacts.mjs paths dist ../../node_modules/.tmp/packages-vue-ui.tsbuildinfo && vite build --config vite.config.ts && vue-tsc -p tsconfig.build.json",
    "type-check": "vue-tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ccd/design-tokens": "workspace:*",
    "@ccd/shared-utils": "workspace:*",
    "@ccd/vue-hooks": "workspace:*",
    "@tanstack/vue-virtual": "catalog:",
    "@vueuse/core": "catalog:",
    "overlayscrollbars": "catalog:",
    "overlayscrollbars-vue": "catalog:",
    "primevue": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:"
  },
  "devDependencies": {
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vue/tsconfig": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
