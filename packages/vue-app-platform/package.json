{
  "name": "@ccd/vue-app-platform",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -f ../../node_modules/.tmp/packages-vue-app-platform.tsbuildinfo && tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm type-check",
    "test": "vitest --root ../.. run packages/vue-app-platform/src/bootstrap.spec.ts packages/vue-app-platform/src/preloader.spec.ts packages/vue-app-platform/src/preloadError.spec.ts --passWithNoTests"
  }
}
