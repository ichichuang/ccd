{
  "name": "ccd",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "uno.css",
    "virtual:*"
  ],
  "author": "Chi Chuang",
  "description": "Self-protecting deterministic multi-runtime platform architecture.",
  "keywords": [
    "vue3",
    "typescript",
    "vite",
    "tauri",
    "monorepo",
    "governance",
    "architecture"
  ],
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "ccd:doctor": "node scripts/ccd-ops.mjs doctor",
    "ccd:fix": "node scripts/ccd-ops.mjs fix",
    "ccd:ship": "node scripts/ccd-ops.mjs ship",
    "generated:normalize": "node scripts/normalize-generated-output.mjs",
    "project:print": "node scripts/project-config.mjs print",
    "project:validate": "node scripts/project-config.mjs validate",
    "project:sync": "node scripts/project-config.mjs sync",
    "project:doctor": "node scripts/project-config.mjs doctor",
    "sync:brand": "node scripts/sync-brand.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "dev": "pnpm dev:web-demo",
    "dev:demo": "cross-env NODE_OPTIONS=--max-old-space-size=8192 UNO_DEMO=true pnpm --filter @ccd/web-demo dev",
    "build": "pnpm build:web-demo",
    "ci:smoke:packages": "node scripts/ci/package-resolution-smoke.mjs",
    "ci:smoke:unocss-tokens": "node scripts/ci/verify-unocss-token-classes.mjs",
    "build:ci": "node scripts/validate-workspace.mjs ci",
    "vercel:build": "pnpm build:web-demo && pnpm ci:smoke:packages",
    "governance:refresh": "pnpm api:report && pnpm supply:check && pnpm arch:report && pnpm arch:graphs && pnpm generated:normalize",
    "budget:bundles": "pnpm build:web-demo && node scripts/check-bundle-budgets.mjs",
    "css:pxtorem:check": "node scripts/architecture/check-css-pxtorem-policy.mjs",
    "preview": "pnpm --filter @ccd/web-demo preview",
    "preview:dist": "pnpm build:web-demo && pnpm dlx serve apps/web-demo/dist",
    "deps:outdated": "pnpm outdated --format table",
    "deps:scan": "node scripts/architecture/dependency-scan-summary.mjs",
    "deps:catalog:check": "node scripts/architecture/check-dependency-catalogs.mjs",
    "deps:update:safe:dry": "pnpm outdated --format table",
    "deps:update:safe": "pnpm update --interactive=false",
    "deps:update:major:plan": "echo \"Major updates must use isolated branches: codex/deps-vite8-runtime-lane, codex/deps-vue-tooling-lane, codex/deps-eslint10-lane. Do not run pnpm up --latest on main.\"",
    "type-check": "turbo run type-check",
    "lint:check": "eslint \"apps/**/*.{vue,ts,tsx,js,jsx}\" \"packages/**/*.{vue,ts,tsx,js,jsx}\" \"scripts/architecture/**/*.mjs\" \"*.{ts,js,mjs,cjs}\"",
    "lint:fix": "eslint \"apps/**/*.{vue,ts,tsx,js,jsx}\" \"packages/**/*.{vue,ts,tsx,js,jsx}\" \"scripts/architecture/**/*.mjs\" \"*.{ts,js,mjs,cjs}\" --fix",
    "lint:staged:safe": "node scripts/lint-staged-safe.mjs",
    "lint:style": "stylelint \"apps/**/*.{css,scss,vue}\" --fix",
    "format": "prettier --write apps/ packages/ scripts/ *.json *.ts *.mjs",
    "fix": "pnpm format && pnpm lint:fix",
    "check": "node scripts/validate-workspace.mjs fast",
    "arch:snapshot": "node scripts/governance/snapshot.mjs",
    "arch:report": "node scripts/governance/report.mjs",
    "arch:visualize": "node scripts/governance/visualize.mjs",
    "env:doctor": "node scripts/env-doctor.mjs",
    "env:doctor:strict": "node scripts/env-doctor.mjs --strict",
    "env:doctor:strict-runtime": "cross-env CCD_RUNTIME_REQUIRE_MISE=1 node scripts/env-doctor.mjs --require-mise",
    "ai-os:doctor": "node scripts/ai-os-doctor.mjs",
    "ai-os:doctor:strict-local": "cross-env STRICT_LOCAL_RUNTIME=1 node scripts/ai-os-doctor.mjs",
    "runtime:env": "bash scripts/env.sh",
    "runtime:env:strict": "cross-env CCD_RUNTIME_REQUIRE_MISE=1 bash scripts/env.sh",
    "runtime:exec": "bash scripts/exec.sh",
    "runtime:exec:strict": "cross-env CCD_RUNTIME_REQUIRE_MISE=1 bash scripts/exec.sh",
    "runtime:bootstrap": "bash scripts/bootstrap-runtime.sh",
    "governance:validate": "node scripts/governance/validate.mjs",
    "governance:gate": "bash scripts/exec.sh node scripts/governance/gate.mjs",
    "docs:commands": "node scripts/governance/check-doc-commands.mjs",
    "governance:github-workflows": "node scripts/governance/check-github-workflow-registry.mjs",
    "drift:repair": "node scripts/governance/drift-repair.mjs",
    "protocol:migrate": "node scripts/governance/protocol-migrate.mjs",
    "adapters:validate": "node scripts/governance/adapters-validate.mjs",
    "orchestration:validate": "node scripts/governance/orchestration-validate.mjs",
    "release:governance": "node scripts/architecture/check-release-governance.mjs",
    "ai:guard": "node scripts/ai-architecture-guard.mjs",
    "ai:scaffold:view-route": "node scripts/ai-route-view-scaffold.mjs",
    "ai:doctor": "node scripts/ai-doctor.mjs",
    "ai:protocol-adapters": "node scripts/generate-ai-protocol-adapters.mjs",
    "ai:rule-index": "node scripts/generate-rule-index.mjs",
    "ai:ledger:json": "node scripts/migrate-ledger.mjs",
    "unocss:ide-data": "node scripts/generate-unocss-ide-data.mjs",
    "validate:tokens": "tsx scripts/validate-token-contrast.ts",
    "ai:sync": "node scripts/ai-sync.mjs",
    "ai:sync:codex": "node scripts/ai-sync-codex.mjs",
    "ai:setup:codex": "pnpm ai:sync && pnpm ai:sync:codex && pnpm ai:doctor && pnpm codex:preflight",
    "ai:clean": "node scripts/ai-clean.mjs",
    "ai:route:skills": "node .ai/skills/codex/task-orchestrator/scripts/skill_router.mjs",
    "ai:route:skills:python": "python3 .ai/skills/codex/task-orchestrator/scripts/skill_router.py",
    "sync:desktop-config": "node scripts/sync-desktop-config.mjs",
    "codex:preflight": "node scripts/codex-preflight.mjs",
    "drift-check": "node scripts/drift-check.mjs",
    "check:drift": "node scripts/drift-check.mjs",
    "test": "vitest",
    "test:run": "pnpm exec turbo run build --filter=\"./packages/*\" && vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:qa": "pnpm ci:prepare-internal && pnpm e2e:qa:prepared",
    "e2e:qa:prepared": "pnpm e2e:smoke && pnpm e2e:perf && pnpm e2e:layout && pnpm e2e:visual",
    "e2e:smoke": "playwright test e2e/qa-regression.spec.ts e2e/views-route-smoke.spec.ts --grep-invert \"@visual|@perf\"",
    "e2e:perf": "playwright test e2e/qa-regression.spec.ts --grep @perf --workers=1 --retries=0",
    "e2e:layout": "playwright test e2e/layout-runtime-geometry.spec.ts --workers=2",
    "e2e:visual": "playwright test e2e/qa-regression.spec.ts e2e/visual-token-foundation.spec.ts --grep @visual --workers=1 --retries=0",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "commit": "git-cz",
    "codex:execute:doctor": "node scripts/diagnostics/codex-execute-doctor.mjs",
    "codex:cache:inspect": "node scripts/diagnostics/codex-cache-inspect.mjs",
    "codex:provider:inspect": "node scripts/diagnostics/codex-provider-inspect.mjs",
    "codex:routing:inspect": "node scripts/diagnostics/codex-routing-inspect.mjs",
    "codex:cache:purge": "node scripts/runtime/cache-governance.mjs purge",
    "codex:cache:fingerprint": "node scripts/runtime/cache-governance.mjs fingerprint",
    "codex:transport:validate": "node scripts/runtime/provider-transport-validate.mjs",
    "codex:exec": "node scripts/runtime/codex-exec-wrapper.mjs",
    "dev:web-demo": "pnpm --filter @ccd/web-demo dev",
    "dev:desktop": "pnpm --filter @ccd/desktop dev",
    "build:web-demo": "cross-env CCD_EXEC_PHASE=\"build @ccd/web-demo and workspace dependencies\" CCD_EXEC_HINT=\"Fix the failing package task above, then rerun pnpm build:web-demo.\" bash scripts/exec.sh pnpm exec turbo run build --filter=\"@ccd/web-demo...\"",
    "build:desktop": "cross-env CCD_EXEC_PHASE=\"build @ccd/desktop and workspace dependencies\" CCD_EXEC_HINT=\"Fix the failing package task above, then rerun pnpm build:desktop.\" bash scripts/exec.sh pnpm exec turbo run build --filter=\"@ccd/desktop...\"",
    "arch:boundaries": "depcruise --config .dependency-cruiser.cjs apps packages && node scripts/architecture/validate-boundaries.mjs",
    "budget:desktop": "pnpm build:desktop && node scripts/architecture/check-desktop-size.mjs",
    "desktop:security": "node scripts/architecture/check-desktop-security.mjs",
    "desktop:smoke": "node scripts/architecture/desktop-smoke.mjs all",
    "desktop:smoke:dev": "node scripts/architecture/desktop-smoke.mjs dev",
    "desktop:smoke:release": "node scripts/architecture/desktop-smoke.mjs release",
    "build:core": "pnpm exec turbo run build --filter='@ccd/core'",
    "build:shared-config": "pnpm exec turbo run build --filter='./packages/*'",
    "ci:clean-artifacts": "node scripts/clean-artifacts.mjs workspace-build",
    "ci:prepare-internal": "pnpm ci:clean-artifacts && cross-env CCD_EXEC_PHASE=\"build internal workspace packages\" CCD_EXEC_HINT=\"Fix the failing package build above before running app builds.\" bash scripts/exec.sh pnpm exec turbo run build --filter=\"./packages/*\"",
    "ci:verify:fresh": "pnpm ci:clean-artifacts && pnpm install --frozen-lockfile && pnpm build:ci",
    "arch:runtime": "node scripts/architecture/check-runtime-leaks.mjs && node scripts/architecture/check-root-runtime-decommissioned.mjs",
    "api:report": "node scripts/architecture/check-api-surface.mjs",
    "supply:check": "node scripts/architecture/check-supply-chain.mjs",
    "governance:full": "pnpm validate:governance",
    "doctor": "pnpm env:doctor && pnpm ai:doctor",
    "arch:graphs": "node scripts/architecture/generate-dependency-graphs.mjs",
    "validate": "node scripts/validate-workspace.mjs full",
    "validate:runtime": "node scripts/runtime/summary.mjs && pnpm arch:runtime && pnpm arch:graphs",
    "validate:governance": "pnpm governance:gate",
    "validate:release": "pnpm validate && node scripts/architecture/check-release-governance.mjs && node scripts/architecture/release-audit.mjs",
    "release:audit": "node scripts/architecture/release-audit.mjs",
    "runtime:summary": "node scripts/runtime/summary.mjs",
    "ccd:ci": "node scripts/ccd-ops.mjs ci",
    "ccd:verify": "node scripts/ccd-ops.mjs ci"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "glob": "catalog:overrides",
      "path-scurry>lru-cache": "catalog:overrides"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "vue-demi"
    ]
  },
  "dependencies": {
    "@primeuix/themes": "catalog:",
    "@primevue/core": "catalog:",
    "@primevue/forms": "catalog:",
    "@primevue/icons": "catalog:",
    "@tanstack/vue-virtual": "catalog:",
    "@vueuse/core": "catalog:",
    "alova": "catalog:",
    "crypto-es": "catalog:",
    "dayjs": "catalog:",
    "echarts": "catalog:",
    "gsap": "catalog:",
    "lodash-es": "catalog:",
    "lz-string": "catalog:",
    "mitt": "catalog:",
    "overlayscrollbars": "catalog:",
    "overlayscrollbars-vue": "catalog:",
    "pinia": "catalog:",
    "pinia-plugin-persistedstate": "catalog:",
    "primevue": "catalog:",
    "uuid": "catalog:",
    "vue": "catalog:",
    "vue-echarts": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:",
    "vue3-lottie": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ccd/contracts": "workspace:*",
    "@ccd/core": "workspace:*",
    "@ccd/design-tokens": "workspace:*",
    "@ccd/shared-utils": "workspace:*",
    "@ccd/unocss-preset": "workspace:*",
    "@ccd/vue-app-platform": "workspace:*",
    "@ccd/vue-charts": "workspace:*",
    "@ccd/vue-hooks": "workspace:*",
    "@ccd/vue-primevue-adapter": "workspace:*",
    "@ccd/vue-ui": "workspace:*",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "@faker-js/faker": "catalog:",
    "@iconify-json/logos": "catalog:",
    "@iconify-json/lucide": "catalog:",
    "@iconify-json/ph": "catalog:",
    "@iconify-json/solar": "catalog:",
    "@iconify/utils": "catalog:",
    "@playwright/test": "catalog:",
    "@primevue/auto-import-resolver": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/postcss-pxtorem": "catalog:",
    "@unocss/preset-attributify": "catalog:",
    "@unocss/preset-icons": "catalog:",
    "@unocss/preset-typography": "catalog:",
    "@unocss/preset-uno": "catalog:",
    "@unocss/reset": "catalog:",
    "@unocss/transformer-directives": "catalog:",
    "@unocss/transformer-variant-group": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vue/compiler-dom": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "@vue/test-utils": "catalog:",
    "@vue/tsconfig": "catalog:",
    "autoprefixer": "catalog:",
    "baseline-browser-mapping": "catalog:",
    "chokidar": "catalog:",
    "commitizen": "catalog:",
    "concurrently": "catalog:",
    "cross-env": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "dependency-cruiser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-boundaries": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "fast-glob": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "jsdom": "catalog:",
    "lint-staged": "catalog:",
    "magic-string": "catalog:",
    "npm-run-all2": "catalog:",
    "picocolors": "catalog:",
    "postcss": "catalog:",
    "postcss-html": "catalog:",
    "postcss-pxtorem": "catalog:",
    "prettier": "catalog:",
    "rollup-plugin-visualizer": "catalog:",
    "sass": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-prettier-scss": "catalog:",
    "stylelint-config-standard-scss": "catalog:",
    "terser": "catalog:",
    "ts-node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "unocss": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-vue-components": "catalog:",
    "vite": "catalog:",
    "vite-plugin-compression": "catalog:",
    "vitest": "catalog:",
    "vue-eslint-parser": "catalog:",
    "vue-tsc": "catalog:",
    "turbo": "catalog:"
  },
