{
  "name": "app-template",
  "version": "1.0.38",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "uno.css",
    "virtual:*"
  ],
  "author": "AppTemplate Team",
  "description": "企业级 Vue 3 后台管理模板",
  "keywords": [
    "vue3",
    "typescript",
    "vite",
    "pinia",
    "alova",
    "admin",
    "framework",
    "enterprise-vue-admin"
  ],
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "sync:brand": "node scripts/sync-brand.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "prebuild": "pnpm build:core",
    "dev": "pnpm dev:web",
    "dev:demo": "NODE_OPTIONS='--max-old-space-size=8192' UNO_DEMO=true pnpm --filter @ccd/web-demo dev",
    "build": "pnpm build:web-demo",
    "build:ci": "pnpm governance:gate && pnpm exec turbo run build",
    "build:analyze": "pnpm build",
    "budget:bundles": "node scripts/check-bundle-budgets.mjs",
    "preview": "pnpm --filter @ccd/web-demo preview",
    "preview:dist": "pnpm build:web-demo && pnpm dlx serve apps/web-demo/dist",
    "report": "pnpm arch:report",
    "deps:outdated": "pnpm outdated --format table",
    "deps:update:safe:dry": "pnpm outdated --format table",
    "deps:update:safe": "pnpm update --interactive=false",
    "deps:update:major:plan": "echo \"Major updates must use isolated branches: codex/deps-vite8-runtime-lane, codex/deps-vue-tooling-lane, codex/deps-eslint10-lane. Do not run pnpm up --latest on main.\"",
    "type-check": "turbo run type-check",
    "lint": "eslint \"apps/**/*.{vue,ts,tsx,js,jsx}\" \"packages/**/*.{vue,ts,tsx,js,jsx}\" \"scripts/architecture/**/*.mjs\" \"*.{ts,js,mjs,cjs}\"",
    "lint:check": "eslint \"apps/**/*.{vue,ts,tsx,js,jsx}\" \"packages/**/*.{vue,ts,tsx,js,jsx}\" \"scripts/architecture/**/*.mjs\" \"*.{ts,js,mjs,cjs}\"",
    "lint:fix": "eslint \"apps/**/*.{vue,ts,tsx,js,jsx}\" \"packages/**/*.{vue,ts,tsx,js,jsx}\" \"scripts/architecture/**/*.mjs\" \"*.{ts,js,mjs,cjs}\" --fix",
    "lint:staged:safe": "node scripts/lint-staged-safe.mjs",
    "lint:style": "stylelint \"apps/**/*.{css,scss,vue}\" --fix",
    "format": "prettier --write apps/ packages/ scripts/ *.json *.ts *.mjs",
    "fix": "pnpm format && pnpm lint:fix",
    "check": "pnpm type-check && pnpm lint:check",
    "arch:check:fast": "pnpm env:doctor && pnpm ai:doctor && pnpm drift-check && pnpm governance:validate",
    "arch:check": "pnpm env:doctor && pnpm ai:sync && pnpm ai:sync:codex && pnpm ai:doctor && pnpm drift-check && pnpm governance:validate && pnpm adapters:validate && pnpm orchestration:validate && pnpm codex:preflight && git diff --check",
    "arch:check:full": "pnpm arch:check && pnpm arch:snapshot && pnpm arch:report && pnpm arch:visualize && pnpm lint && pnpm type-check && pnpm test:run",
    "arch:snapshot": "node scripts/governance/snapshot.mjs",
    "arch:report": "node scripts/governance/report.mjs",
    "arch:visualize": "node scripts/governance/visualize.mjs",
    "env:doctor": "node scripts/env-doctor.mjs",
    "env:doctor:strict": "node scripts/env-doctor.mjs --strict",
    "env:doctor:strict-runtime": "CCD_RUNTIME_REQUIRE_MISE=1 node scripts/env-doctor.mjs --require-mise",
    "ai-os:doctor": "node scripts/ai-os-doctor.mjs",
    "ai-os:doctor:strict-local": "STRICT_LOCAL_RUNTIME=1 node scripts/ai-os-doctor.mjs",
    "runtime:env": "bash scripts/env.sh",
    "runtime:env:strict": "CCD_RUNTIME_REQUIRE_MISE=1 bash scripts/env.sh",
    "runtime:exec": "bash scripts/exec.sh",
    "runtime:exec:strict": "CCD_RUNTIME_REQUIRE_MISE=1 bash scripts/exec.sh",
    "runtime:bootstrap": "bash scripts/bootstrap-runtime.sh",
    "governance:validate": "node scripts/governance/validate.mjs",
    "governance:gate": "node scripts/governance/gate.mjs",
    "governance:github-workflows": "node scripts/governance/check-github-workflow-registry.mjs",
    "drift:repair": "node scripts/governance/drift-repair.mjs",
    "protocol:migrate": "node scripts/governance/protocol-migrate.mjs",
    "adapters:validate": "node scripts/governance/adapters-validate.mjs",
    "orchestration:validate": "node scripts/governance/orchestration-validate.mjs",
    "release:governance": "node scripts/architecture/check-release-governance.mjs",
    "release:check": "pnpm arch:check:full && pnpm release:governance && pnpm build:ci",
    "ai:guard": "node scripts/ai-architecture-guard.mjs",
    "ai:scaffold:view-route": "node scripts/ai-route-view-scaffold.mjs",
    "ai:doctor": "node scripts/ai-doctor.mjs",
    "ai:doctor:open": "node scripts/ai-doctor.mjs --open",
    "ai:protocol-adapters": "node scripts/generate-ai-protocol-adapters.mjs",
    "ai:rule-index": "node scripts/generate-rule-index.mjs",
    "ai:ledger:json": "node scripts/migrate-ledger.mjs",
    "unocss:ide-data": "node scripts/generate-unocss-ide-data.mjs",
    "validate:tokens": "tsx scripts/validate-token-contrast.ts",
    "ai:sync": "node scripts/ai-sync.mjs",
    "ai:sync:codex": "node scripts/ai-sync-codex.mjs",
    "ai:setup:codex": "pnpm ai:sync && pnpm ai:sync:codex && pnpm ai:doctor && pnpm codex:preflight",
    "ai:clean": "node scripts/ai-clean.mjs",
    "ai:route:skills": "node .ai/skills/codex/task-orchestrator/scripts/skill_router.mjs",
    "ai:route:skills:python": "python3 .ai/skills/codex/task-orchestrator/scripts/skill_router.py",
    "sync:desktop-config": "node scripts/sync-desktop-config.mjs",
    "codex:preflight": "node scripts/codex-preflight.mjs",
    "drift-check": "node scripts/drift-check.mjs",
    "check:drift": "node scripts/drift-check.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:qa": "playwright test e2e/qa-regression.spec.ts e2e/views-route-smoke.spec.ts e2e/layout-runtime-geometry.spec.ts",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "commit": "git-cz",
    "codex:execute:doctor": "node scripts/diagnostics/codex-execute-doctor.mjs",
    "codex:cache:inspect": "node scripts/diagnostics/codex-cache-inspect.mjs",
    "codex:provider:inspect": "node scripts/diagnostics/codex-provider-inspect.mjs",
    "codex:routing:inspect": "node scripts/diagnostics/codex-routing-inspect.mjs",
    "codex:cache:purge": "node scripts/runtime/cache-governance.mjs purge",
    "codex:cache:fingerprint": "node scripts/runtime/cache-governance.mjs fingerprint",
    "codex:transport:validate": "node scripts/runtime/provider-transport-validate.mjs",
    "codex:exec": "node scripts/runtime/codex-exec-wrapper.mjs",
    "dev:web-demo": "pnpm --filter @ccd/web-demo dev",
    "dev:desktop": "pnpm --filter @ccd/desktop dev",
    "build:web-demo": "pnpm build:core && pnpm --filter @ccd/web-demo build",
    "build:desktop": "pnpm build:core && pnpm --filter @ccd/desktop build",
    "type-check:workspaces": "turbo run type-check",
    "arch:boundaries": "depcruise --config .dependency-cruiser.cjs apps packages && node scripts/architecture/validate-boundaries.mjs",
    "budget:desktop": "node scripts/architecture/check-desktop-size.mjs",
    "monorepo:check": "pnpm governance:gate && pnpm type-check && pnpm arch:runtime",
    "build:core": "pnpm --filter @ccd/contracts build && pnpm --filter @ccd/core build",
    "typecheck": "pnpm type-check",
    "arch:runtime": "node scripts/architecture/check-runtime-leaks.mjs && node scripts/architecture/check-root-runtime-decommissioned.mjs",
    "api:report": "node scripts/architecture/check-api-surface.mjs",
    "supply:check": "node scripts/architecture/check-supply-chain.mjs",
    "governance:full": "pnpm governance:gate",
    "affected:lint": "turbo run lint --affected",
    "affected:test": "turbo run test --affected",
    "affected:typecheck": "turbo run type-check --affected",
    "affected:build": "turbo run build --affected",
    "dev:web": "pnpm --filter @ccd/web-demo dev"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "glob": "^11.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "vue-demi"
    ]
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/core": "^4.5.4",
    "@primevue/forms": "^4.5.4",
    "@primevue/icons": "^4.5.4",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vueuse/core": "^13.9.0",
    "alova": "^3.3.3",
    "crypto-es": "^3.1.2",
    "dayjs": "^1.11.13",
    "echarts": "^6.0.0",
    "gsap": "^3.14.2",
    "lodash-es": "^4.17.21",
    "lz-string": "^1.5.0",
    "mitt": "^3.0.1",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-vue": "^0.5.9",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primevue": "^4.5.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.12",
    "vue-echarts": "^8.0.0",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.4.5",
    "vue3-lottie": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^9.9.0",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/lucide": "^1.2.86",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/solar": "^1.2.5",
    "@iconify/utils": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@primevue/auto-import-resolver": "^4.5.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.7.0",
    "@types/postcss-pxtorem": "^6.1.0",
    "@unocss/preset-attributify": "^66.6.0",
    "@unocss/preset-icons": "^66.6.0",
    "@unocss/preset-typography": "^66.6.0",
    "@unocss/preset-uno": "^66.6.0",
    "@unocss/reset": "^66.6.0",
    "@unocss/transformer-directives": "^66.6.0",
    "@unocss/transformer-variant-group": "^66.6.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vue/compiler-sfc": "^3.5.29",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.23",
    "baseline-browser-mapping": "^2.9.19",
    "chokidar": "^4.0.3",
    "commitizen": "^4.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-vue": "^9.31.0",
    "fast-glob": "^3.3.3",
    "glob": "^11.1.0",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.11",
    "magic-string": "^0.30.21",
    "npm-run-all2": "^7.0.2",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.1",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser": "^5.46.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.1",
    "unocss": "^66.6.0",
    "unplugin-auto-import": "^20.0.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-progress": "^0.0.7",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.10",
    "turbo": "^2.6.3"
  }
}
