---
description: Color semantic usage; hover uses primary-hover, accent is independent highlight
globs: src/**/*.{vue,ts,tsx}
alwaysApply: true
---

<rule>
  <context>
    This rule defines how to map UI intentions to semantic color tokens defined in <file>src/constants/theme/colorUsage.ts</file>.
    Colors must be chosen by semantic meaning, not by visual guessing or ad-hoc classes.
  </context>

  <constraints>
    <section name="semantic-mapping">
      <rule>Use <code>primary</code> for brand and primary CTAs (for example <code>bg-primary</code>, <code>text-primary</code>).</rule>
      <rule>Use <code>primary-hover</code> for hover feedback on primary actions (for example <code>hover:bg-primary-hover</code>, <code>hover:text-primary-hover</code>).</rule>
      <rule>Use <code>primary-light</code> for focus preselection and subtle highlight backgrounds (for example list item focus states).</rule>
      <rule>Use <code>accent</code> as an independent highlight color for elements like tab indicators, special markers, and badges, not for hover or focus.</rule>
      <rule>Use <code>ring</code> for focus rings (for example <code>focus:ring-ring</code>), never <code>focus:ring-primary</code>.</rule>
      <rule>Use <code>neutral</code> for structural layout surfaces (for example <code>bg-secondary</code>, <code>border-border</code>).</rule>
    </section>

    <section name="component-mapping">
      <rule>For buttons:
        <list>
          <item>Filled state uses <code>primary</code>.</item>
          <item>Ghost hover uses <code>primary-hover</code> (for example low-opacity overlays).</item>
        </list>
      </rule>
      <rule>For inputs:
        <list>
          <item>Hover border uses <code>primary-hover</code>.</item>
          <item>Focus border and ring use <code>ring</code>.</item>
        </list>
      </rule>
      <rule>For select options:
        <list>
          <item>Focus background uses <code>primary-light</code>.</item>
          <item>Selected state uses <code>primary</code>.</item>
        </list>
      </rule>
      <rule>For table rows, hover background uses a <code>primary-hover</code>-derived token (for example <code>primary-hover/0.12</code> via design system).</rule>
      <rule>For tabs and badges, active indicators and highlights use <code>accent</code>.</rule>
    </section>
  </constraints>

  <forbidden>
    <item>Using <code>hover:bg-accent</code> or <code>hover:text-accent</code> for standard hover feedback; use <code>primary-hover</code> instead.</item>
    <item>Using <code>focus:ring-primary</code> instead of <code>focus:ring-ring</code>.</item>
    <item>Using <code>bg-accent-light</code> as selection background where <code>bg-primary-light</code> should be used.</item>
  </forbidden>

  <communication>
    Output Requirement: Always explain color choices and semantic mappings to the user in fluent Chinese, while keeping class names and token identifiers in English.
  </communication>

  <examples>
    <example>
      When designing a primary button, use <code>bg-primary text-foreground</code> with <code>hover:bg-primary-hover</code>, and focus styling via <code>focus:ring-ring</code>.
    </example>
    <example>
      When designing a tab bar, use <code>accent</code> for the active tab indicator line, not <code>primary</code>, to keep it visually distinct from primary CTAs.</example>
  </examples>
</rule>
